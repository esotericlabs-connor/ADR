# ADR optional AI configuration
#
# Copy this file to adr.env in the same folder as adr.ps1/adr.sh, then fill in
# only the provider you want to use. ADR does not require any AI key unless you
# explicitly run with -UseAiEnrichment or --ai.
#
# Do not paste customer data, passwords, Wi-Fi keys, product keys, or ticket
# secrets into this file.

# Provider selection:
#   auto, openai, claude, gemini, perplexity, mistral, openai-compatible
ADR_AI_PROVIDER=auto

# Global overrides, mostly useful for openai-compatible/custom gateways.
# ADR_AI_API_KEY=
# ADR_AI_MODEL=
# ADR_AI_ENDPOINT=

# OpenAI
# OPENAI_API_KEY=
# ADR_OPENAI_MODEL=gpt-5.2
# ADR_OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions

# Claude / Anthropic
# ANTHROPIC_API_KEY=
# ADR_CLAUDE_MODEL=claude-sonnet-4-5
# ADR_CLAUDE_ENDPOINT=https://api.anthropic.com/v1/messages

# Gemini / Google AI
# GEMINI_API_KEY=
# ADR_GEMINI_MODEL=gemini-2.5-flash
# ADR_GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent

# Perplexity
# PERPLEXITY_API_KEY=
# ADR_PERPLEXITY_MODEL=sonar
# ADR_PERPLEXITY_ENDPOINT=https://api.perplexity.ai/v1/sonar

# Mistral
# MISTRAL_API_KEY=
# ADR_MISTRAL_MODEL=mistral-large-latest
# ADR_MISTRAL_ENDPOINT=https://api.mistral.ai/v1/chat/completions

# Backward-compatible names from earlier ADR builds.
# DIAG_AI_PROVIDER=
# DIAG_AI_API_KEY=
# DIAG_AI_MODEL=
# DIAG_AI_ENDPOINT=
